menu "Trợ lý Xiaozhi"

config OTA_URL
    string "URL OTA mặc định"
    default "https://api.tenclass.net/xiaozhi/ota/"
    help
        Ứng dụng sẽ truy cập URL này để kiểm tra firmware mới và địa chỉ server.

choice
    prompt "Nạp tài nguyên Flash"
    default FLASH_DEFAULT_ASSETS if !USE_EMOTE_MESSAGE_STYLE
    default FLASH_EXPRESSION_ASSETS if USE_EMOTE_MESSAGE_STYLE
    help
        Chọn tài nguyên cần nạp vào flash.

    config FLASH_NONE_ASSETS
        bool "Không nạp tài nguyên"
    config FLASH_DEFAULT_ASSETS
        bool "Nạp tài nguyên mặc định"
        depends on !USE_EMOTE_MESSAGE_STYLE
    config FLASH_CUSTOM_ASSETS
        bool "Nạp tài nguyên tùy chỉnh"
    config FLASH_EXPRESSION_ASSETS
        bool "Nạp tài nguyên biểu cảm"
        depends on USE_EMOTE_MESSAGE_STYLE
endchoice

config CUSTOM_ASSETS_FILE
    depends on FLASH_CUSTOM_ASSETS
    string "Tệp tài nguyên tùy chỉnh"
    default "assets.bin"
    help
        Tệp tài nguyên tùy chỉnh cần nạp vào flash.
        Có thể là tệp cục bộ (đường dẫn tương đối so với thư mục dự án) hoặc URL từ xa.

choice
    prompt "Ngôn ngữ mặc định"
