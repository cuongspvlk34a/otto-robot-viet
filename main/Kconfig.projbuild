choice DISPLAY_STYLE
    prompt "Chọn kiểu hiển thị"
    default USE_DEFAULT_MESSAGE_STYLE
    help
        Chọn kiểu hiển thị cho thiết bị Xiaozhi

    config USE_DEFAULT_MESSAGE_STYLE
        bool "Kiểu tin nhắn mặc định"

    config USE_WECHAT_MESSAGE_STYLE
        bool "Kiểu tin nhắn WeChat"

    config USE_EMOTE_MESSAGE_STYLE
        bool "Kiểu hoạt ảnh biểu cảm"
        depends on BOARD_TYPE_ESP_BOX || BOARD_TYPE_ESP_BOX_3 \
            || BOARD_TYPE_ESP_VOCAT || BOARD_TYPE_LICHUANG_DEV_S3 || BOARD_TYPE_RYMCU_BIGSMART \
            || BOARD_TYPE_ESP_SENSAIRSHUTTLE
endchoice

config USE_MULTILINE_CHAT_MESSAGE
    bool "Hiển thị tin nhắn nhiều dòng (chỉ chế độ mặc định)"
    depends on USE_DEFAULT_MESSAGE_STYLE
    default n
    help
        Khi bật, vùng hiển thị tin nhắn trong chế độ mặc định sẽ hiển thị
        nhiều dòng được bọc lại, mở rộng từ dưới lên trên màn hình,
        với chiều cao tự thích nghi.
        Khi tắt (mặc định), hiển thị một dòng cuộn ngang duy nhất
        ở cuối màn hình.

choice WAKE_WORD_TYPE
    prompt "Loại triển khai Wake Word"
    default USE_AFE_WAKE_WORD if (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
    default WAKE_WORD_DISABLED
    help
        Chọn loại triển khai wake word sẽ sử dụng

    config WAKE_WORD_DISABLED
        bool "Tắt"
        help
            Tắt tính năng nhận diện wake word

    config USE_ESP_WAKE_WORD
        bool "Mô hình Wakenet không có AFE"
        depends on IDF_TARGET_ESP32C3 || IDF_TARGET_ESP32C5 || IDF_TARGET_ESP32C6 || (IDF_TARGET_ESP32 && SPIRAM)
        help
            Hỗ trợ ESP32 C3, ESP32 C5 và ESP32 C6, và (ESP32 với PSRAM)

    config USE_AFE_WAKE_WORD
        bool "Mô hình Wakenet với AFE"
        depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
        help
            Hỗ trợ AEC nếu có, yêu cầu ESP32 S3 và PSRAM

    config USE_CUSTOM_WAKE_WORD
        bool "Mô hình Multinet (Wake Word tùy chỉnh)"
        depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
        help
            Yêu cầu ESP32 S3 và PSRAM

endchoice

config CUSTOM_WAKE_WORD
    string "Wake Word tùy chỉnh"
    default "xiao tu dou"
    depends on USE_CUSTOM_WAKE_WORD
    help
        Wake word tùy chỉnh, dùng phiên âm pinyin cho tiếng Trung, phân cách bằng dấu cách

config CUSTOM_WAKE_WORD_DISPLAY
    string "Hiển thị Wake Word tùy chỉnh"
    default "小土豆"
    depends on USE_CUSTOM_WAKE_WORD
    help
        Lời chào gửi đến server sau khi nhận diện được wake word

config CUSTOM_WAKE_WORD_THRESHOLD
    int "Ngưỡng Wake Word tùy chỉnh (%)"
    default 20
    range 1 99
    depends on USE_CUSTOM_WAKE_WORD
    help
        Ngưỡng wake word tùy chỉnh, phạm vi 1-99, giá trị càng nhỏ càng nhạy, mặc định 20

config SEND_WAKE_WORD_DATA
    bool "Gửi dữ liệu Wake Word"
    default y
    depends on USE_AFE_WAKE_WORD || USE_CUSTOM_WAKE_WORD
    help
        Gửi dữ liệu wake word đến server như tin nhắn đầu tiên của cuộc trò chuyện và chờ phản hồi

config WAKE_WORD_DETECTION_IN_LISTENING
    bool "Bật nhận diện Wake Word trong chế độ lắng nghe"
    default n
    depends on USE_AFE_WAKE_WORD || USE_CUSTOM_WAKE_WORD
    help
        Bật nhận diện wake word trong khi đang ở chế độ lắng nghe.
        Khi bật, thiết bị có thể phát hiện wake word trong lúc lắng nghe,
        cho phép ngắt cuộc hội thoại hiện tại.
        Khi tắt (mặc định), nhận diện wake word bị vô hiệu hóa trong lúc lắng nghe.

config USE_AUDIO_PROCESSOR
    bool "Bật khử nhiễu âm thanh"
    default y
    depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
    help
        Yêu cầu ESP32 S3 và PSRAM

config USE_DEVICE_AEC
    bool "Bật AEC phía thiết bị"
    default n
        depends on USE_AUDIO_PROCESSOR && (BOARD_TYPE_ESP_BOX_3 || BOARD_TYPE_ESP_BOX || BOARD_TYPE_ESP_BOX_LITE \
        || BOARD_TYPE_LICHUANG_DEV_S3 || BOARD_TYPE_RYMCU_BIGSMART || BOARD_TYPE_ESP_KORVO2_V3 || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_1_75|| BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_1_75C || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_1_83\
        || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_2_06 || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_4B || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4B || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4_3 \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_7B \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_3_4C || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4C || BOARD_TYPE_ESP_S3_LCD_EV_Board_2 || BOARD_TYPE_YUNLIAO_S3 \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_7 || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_8 || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_10_1 \
        || BOARD_TYPE_ESP_VOCAT || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_3_49 || BOARD_TYPE_WAVESHARE_ESP32_S3_RLCD_4_2 || BOARD_TYPE_ZHENGCHEN_CAM || BOARD_TYPE_ZHENGCHEN_CAM_ML307 \
        || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_4_3C || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_1_54 || BOARD_TYPE_WAVESHARE_ESP32_S3_LCD_0_85 || BOARD_TYPE_AI_VOX3 || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_1_43C)
    help
        Để hoạt động đúng, AEC phía thiết bị yêu cầu đường tham chiếu đầu ra sạch từ tín hiệu loa và cách âm vật lý giữa micro và loa.

config USE_SERVER_AEC
    bool "Bật AEC phía server (Không ổn định)"
    default n
    depends on USE_AUDIO_PROCESSOR
    help
        Để hoạt động đúng, AEC phía server yêu cầu server hỗ trợ tính năng này

config USE_AUDIO_DEBUGGER
    bool "Bật chế độ gỡ lỗi âm thanh"
    default n
    help
        Bật chế độ gỡ lỗi âm thanh, gửi dữ liệu âm thanh qua UDP đến máy chủ

menu "Phương thức cấu hình WiFi"
    help
        Chọn phương thức cấu hình WiFi
    config USE_HOTSPOT_WIFI_PROVISIONING
        bool "Điểm truy cập (Hotspot)"
        default y
        help
            Sử dụng WiFi Hotspot để truyền dữ liệu cấu hình WiFi
    config USE_ACOUSTIC_WIFI_PROVISIONING
        bool "Âm thanh"
        help
            Sử dụng tín hiệu âm thanh để truyền dữ liệu cấu hình WiFi

    config USE_ESP_BLUFI_WIFI_PROVISIONING
        bool "Esp Blufi"
        help
            Sử dụng giao thức ESP BluFi để truyền dữ liệu cấu hình WiFi
        select BT_ENABLED
        select BT_BLE_42_FEATURES_SUPPORTED
        select BT_BLE_BLUFI_ENABLE
        select MBEDTLS_DHM_C
endmenu

config AUDIO_DEBUG_UDP_SERVER
    string "Địa chỉ UDP Server gỡ lỗi âm thanh"
    default "192.168.2.100:8000"
    depends on USE_AUDIO_DEBUGGER
    help
        Địa chỉ UDP server, định dạng: IP:PORT, dùng để nhận dữ liệu gỡ lỗi âm thanh

config RECEIVE_CUSTOM_MESSAGE
    bool "Bật nhận tin nhắn tùy chỉnh"
    default n
    help
        Bật tính năng nhận tin nhắn tùy chỉnh, cho phép thiết bị nhận tin nhắn tùy chỉnh từ server (ưu tiên qua giao thức MQTT)

menu "Cấu hình Camera"
    depends on !IDF_TARGET_ESP32

    comment "Cảnh báo: Vui lòng đọc phần trợ giúp trước khi thay đổi các cài đặt này."

    config XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        bool "Cho phép đầu vào JPEG"
        default n
        help
            Cho phép định dạng đầu vào JPEG cho camera.

            Tùy chọn này có thể cần bật khi sử dụng camera USB.

            Hiện chưa hỗ trợ khi dùng đồng thời với XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE.

    config XIAOZHI_ENABLE_HARDWARE_JPEG_ENCODER
        bool "Bật bộ mã hóa JPEG phần cứng"
        default y
        depends on SOC_JPEG_ENCODE_SUPPORTED
        help
            Sử dụng bộ mã hóa JPEG phần cứng trên ESP32-P4 để mã hóa ảnh sang JPEG.
            Xem thêm tại https://docs.espressif.com/projects/esp-idf/en/stable/esp32p4/api-reference/peripherals/jpeg.html

    config XIAOZHI_ENABLE_HARDWARE_JPEG_DECODER
        bool "Bật bộ giải mã JPEG phần cứng"
        default n
        depends on SOC_JPEG_DECODE_SUPPORTED && XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        help
            Sử dụng bộ giải mã JPEG phần cứng trên ESP32-P4 để giải mã JPEG thành ảnh.
            Xem thêm tại https://docs.espressif.com/projects/esp-idf/en/stable/esp32p4/api-reference/peripherals/jpeg.html

    config XIAOZHI_ENABLE_CAMERA_DEBUG_MODE
        bool "Bật chế độ gỡ lỗi Camera"
        default n
        help
            Bật chế độ gỡ lỗi camera, in thông tin debug camera ra console.
            Chỉ hoạt động trên các bo mạch hỗ trợ camera.

    config XIAOZHI_ENABLE_CAMERA_ENDIANNESS_SWAP
        bool "Bật hoán đổi endianness bộ đệm camera bằng phần mềm"
        default n
        depends on !CAMERA_SENSOR_SWAP_PIXEL_BYTE_ORDER
        help
            Tùy chọn này xử lý bộ đệm camera như một mảng uint16_t[] và thực hiện
            hoán đổi byte (chuyển đổi endianness) trên từng phần tử.

            Chỉ nên được chỉnh sửa bởi kỹ sư tích hợp bo mạch phát triển.

            **Sử dụng sai có thể gây ra màu sắc hình ảnh không chính xác!**

            LƯU Ý: Nếu tùy chọn CAMERA_SENSOR_SWAP_PIXEL_BYTE_ORDER có sẵn cho cảm biến của bạn, hãy ưu tiên dùng tùy chọn đó.

    menuconfig XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE
        bool "Bật xoay ảnh Camera"
        default n
        depends on !XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        help
            Bật tính năng xoay ảnh camera về đúng hướng.
            - Trên ESP32-P4, xoay ảnh được xử lý bởi phần cứng PPA.
            - Trên các chip khác, xoay ảnh thực hiện bằng phần mềm và có chi phí hiệu năng.
            - Để xoay 180°, dùng HFlip + VFlip thay vì tùy chọn này.

            Hiện chưa hỗ trợ khi dùng đồng thời với XIAOZHI_CAMERA_ALLOW_JPEG_INPUT.

    if XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE
        choice XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE
            prompt "Góc xoay ảnh Camera (theo chiều kim đồng hồ)"
            default XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_90
            help
                Góc xoay ảnh camera.
            config XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_90
                bool "90°"
            config XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_270
                bool "270°"
            comment "Để xoay 180°, dùng HFlip + VFlip thay vì tùy chọn này"
        endchoice
    endif
endmenu

menu "TAIJIPAI_S3_CONFIG"
    depends on BOARD_TYPE_TAIJI_PI_S3
    choice I2S_TYPE_TAIJIPI_S3
        prompt "Loại I2S taiji-pi-S3"
        default TAIJIPAI_I2S_TYPE_STD
        help
            Chọn loại I2S
        config TAIJIPAI_I2S_TYPE_STD
            bool "I2S Type STD"
        config TAIJIPAI_I2S_TYPE_PDM
            bool "I2S Type PDM"
    endchoice

    config I2S_USE_2SLOT
    bool "Bật I2S 2 kênh"
    default y
    help
        Bật chế độ hai kênh âm thanh
endmenu

endmenu
